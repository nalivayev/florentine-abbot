{

  "help": [
    "Configuration for Preview Maker.",
    "",
    "priority:",
    "  Ordered glob patterns for source files.",
    "  First match wins when multiple sources exist for the same shot.",
    "",
    "template:",
    "  Template for preview filename stem (without extension).",
    "  Uses {field} / {field:spec} syntax.",
    "  The preview marker (e.g. PRV) is a literal part of the template.",
    "",
    "image:",
    "  size   — Maximum long edge in pixels (default: 2000).",
    "  format — Output image format: jpeg, png, webp (default: jpeg).",
    "  jpeg   — JPEG-specific: quality 1-100 (default: 80).",
    "  webp   — WebP-specific: quality 1-100 (default: 80).",
    "  png    — PNG-specific: optimize true/false (default: true)."
  ],

  "priority": [
    "*.MSR.*",
    "*.RAW.*"
  ],

  "template": "{year:04d}.{month:02d}.{day:02d}.{hour:02d}.{minute:02d}.{second:02d}.{modifier}.{group}.{subgroup}.{sequence:04d}.{side}.PRV",

  "image": {

    "size": 2000,
    "format": "jpeg",
    
    "jpeg": {
      "quality": 80
    },
    
    "webp": {
      "quality": 80
    },
    
    "png": {
      "optimize": true
    }
  }

}
